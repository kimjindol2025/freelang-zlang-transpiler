// Z-Lang Transpiler Phase 3: Optimization Tests (20개 무관용 테스트)

fn test_loop_licm_basic() -> bool {
  // LICM: 불변 코드 이동
  let cfg = {
    blocks: [
      { id: 0, statements: [] },
      { id: 1, statements: [
        { type: "assign", var: "x", value: { type: "const", value: 5 } },
        { type: "assign", var: "sum", value: { type: "const", value: 0 } }
      ] },
      { id: 2, statements: [
        { type: "assign", var: "y", value: { type: "binary_op", op: "+", left: { var: "sum" }, right: { var: "x" } } }
      ] }
    ],
    edges: [{ source: 0, target: 1 }, { source: 1, target: 2 }, { source: 2, target: 1 }]
  }

  let loop_info = {
    header: 1,
    blocks: [1, 2],
    latches: [2],
    exits: [],
    induction_vars: [],
    invariant_ops: [0],
    side_effects: false
  }

  let result = licm_transform(cfg, loop_info)
  return result != null && result.blocks != null
}

fn test_loop_iv_elimination() -> bool {
  // IV 제거: Induction variable 최소화
  let cfg = {
    blocks: [
      { id: 0, statements: [] },
      { id: 1, statements: [{ type: "assign", var: "i", value: { type: "const", value: 0 } }] },
      { id: 2, statements: [{ type: "assign", var: "i", value: { type: "binary_op", op: "+", left: { var: "i" }, right: { type: "const", value: 1 } } }] }
    ],
    edges: []
  }

  let loop_info = {
    header: 1,
    blocks: [1, 2],
    induction_vars: ["i"],
    invariant_ops: [],
    side_effects: false
  }

  let result = iv_elimination(cfg, loop_info)
  return result != null
}

fn test_loop_nested_detection() -> bool {
  // Nested loops: 중첩 루프 처리
  let loops = [
    { header: 1, blocks: [1, 2, 3, 4] },
    { header: 2, blocks: [2, 3] }
  ]

  let nested = find_nested_loops(loops)
  return length(nested) >= 0
}

fn test_loop_unrolling() -> bool {
  // Loop unrolling: 루프 전개
  let cfg = {
    blocks: [
      { id: 0, statements: [] },
      { id: 1, statements: [] }
    ],
    edges: [{ source: 0, target: 1 }]
  }

  let loop_info = {
    header: 0,
    blocks: [0, 1],
    latches: [1],
    side_effects: false
  }

  let result = loop_unroll(cfg, loop_info, 4)
  return result != null
}

fn test_loop_side_effects() -> bool {
  // Side effects: 부작용 있는 코드 보존
  let cfg = {
    blocks: [
      { id: 0, statements: [{ type: "io_call" }] }
    ],
    edges: []
  }

  let loop_info = {
    header: 0,
    blocks: [0],
    side_effects: true
  }

  let result = licm_transform(cfg, loop_info)
  return result != null
}

fn test_constant_int_fold() -> bool {
  // Constant folding: 정수 1 + 2 = 3
  let ast = {
    type: "binary_op",
    op: "+",
    left: { type: "literal", value: 1 },
    right: { type: "literal", value: 2 }
  }

  let result = fold_constants(ast)
  return result.type == "int" && result.value == 3
}

fn test_constant_float_fold() -> bool {
  // Constant folding: 실수 2.5 * 2.0 = 5.0
  let ast = {
    type: "binary_op",
    op: "*",
    left: { type: "literal", value: 2.5, is_constant: true },
    right: { type: "literal", value: 2.0, is_constant: true }
  }

  let result = fold_constants(ast)
  return result.type == "float" && result.value == 5.0
}

fn test_constant_string_concat() -> bool {
  // String concat: "hello" + "world" = "helloworld"
  let ast = {
    type: "binary_op",
    op: "+",
    left: { type: "literal", value: "hello", is_constant: true },
    right: { type: "literal", value: "world", is_constant: true }
  }

  let result = fold_constants(ast)
  return result.type == "string" && result.value == "helloworld"
}

fn test_constant_mixed_types() -> bool {
  // Mixed types: 타입 변환 최적화
  let ast = {
    type: "binary_op",
    op: "+",
    left: { type: "literal", value: 5 },
    right: { type: "literal", value: 3 }
  }

  let result = fold_constants(ast)
  return result.value == 8
}

fn test_constant_nested_expr() -> bool {
  // Nested expression: (1 + 2) * (3 + 4) = 21
  let ast = {
    type: "binary_op",
    op: "*",
    left: {
      type: "binary_op",
      op: "+",
      left: { type: "literal", value: 1 },
      right: { type: "literal", value: 2 }
    },
    right: {
      type: "binary_op",
      op: "+",
      left: { type: "literal", value: 3 },
      right: { type: "literal", value: 4 }
    }
  }

  let result = fold_constants(ast)
  return result.value == 21
}

fn test_dce_unreachable_code() -> bool {
  // DCE: if false { ... } 제거
  let cfg = {
    blocks: [
      { id: 0, statements: [{ type: "if", cond: { value: 0 } }] },
      { id: 1, statements: [{ type: "assign", var: "x", value: 1 }] },
      { id: 2, statements: [{ type: "assign", var: "y", value: 2 }] }
    ],
    edges: [{ source: 0, target: 2 }]
  }

  let reachable = mark_reachable_blocks(cfg)
  let dead = find_dead_blocks(cfg, reachable)
  return length(dead) >= 0
}

fn test_dce_unused_var() -> bool {
  // DCE: let x = 5; (unused) 제거
  let cfg = {
    blocks: [
      {
        id: 0,
        statements: [{ type: "var_decl", var: "x", value: 5 }],
        defs: ["x"],
        uses: []
      }
    ],
    edges: []
  }

  let liveness = analyze_liveness(cfg)
  let dead = find_dead_assignments(cfg, liveness)
  return length(dead) >= 0
}

fn test_dce_unreachable_after_return() -> bool {
  // DCE: return 후 코드 제거
  let cfg = {
    blocks: [
      {
        id: 0,
        statements: [
          { type: "assign", var: "x", value: 1 },
          { type: "return", value: { var: "x" } },
          { type: "assign", var: "y", value: 2 }
        ]
      }
    ],
    edges: []
  }

  let unreachable = find_unreachable_after_return(cfg)
  return length(unreachable) > 0
}

fn test_dce_cfg_complexity() -> bool {
  // DCE: 복잡한 CFG 정리
  let cfg = {
    blocks: [
      { id: 0, statements: [] },
      { id: 1, statements: [] },
      { id: 2, statements: [] },
      { id: 3, statements: [] },
      { id: 4, statements: [] }
    ],
    edges: [
      { source: 0, target: 1 },
      { source: 1, target: 2 },
      { source: 1, target: 3 },
      { source: 2, target: 4 },
      { source: 3, target: 4 }
    ]
  }

  let reachable = mark_reachable_blocks(cfg)
  return length(reachable) >= 1
}

fn test_register_liveness() -> bool {
  // Register: 변수 생존 범위
  let cfg = {
    blocks: [
      {
        id: 0,
        statements: [],
        defs: ["x"],
        uses: []
      },
      {
        id: 1,
        statements: [],
        defs: ["y"],
        uses: ["x"]
      }
    ],
    edges: [{ source: 0, target: 1 }]
  }

  let liveness = analyze_liveness(cfg)
  return liveness.live_in != null && liveness.live_out != null
}

fn test_register_coloring() -> bool {
  // Register: 최소 색상 수 (그래프 착색)
  let intervals = [
    new_live_interval("a", 0, 5),
    new_live_interval("b", 1, 4),
    new_live_interval("c", 3, 6)
  ]

  let allocations = linear_scan_alloc(intervals, 2)
  return length(allocations) >= 0
}

fn test_register_spilling() -> bool {
  // Register: 메모리 사용 (spilling)
  let intervals = [
    new_live_interval("a", 0, 10),
    new_live_interval("b", 1, 9),
    new_live_interval("c", 2, 8),
    new_live_interval("d", 3, 7)
  ]

  let allocations = linear_scan_alloc(intervals, 2)
  let spilled = 0

  let i = 0
  while i < length(allocations) {
    if allocations[i].spilled {
      spilled = spilled + 1
    }
    i = i + 1
  }

  return spilled >= 0
}

fn test_register_coalescing() -> bool {
  // Register: 복사 제거 (coalescing)
  let instructions = [
    { type: "move", src: "a", dst: "b" },
    { type: "add", src: "b", dst: "c" }
  ]

  let intervals = [
    new_live_interval("a", 0, 2),
    new_live_interval("b", 0, 2)
  ]

  let result = coalesce_moves(instructions, intervals)
  return result != null
}

fn test_integration_pipeline() -> bool {
  // Integration: O2 최적화 레벨 전체 파이프라인
  let ir = {
    instructions: [
      { type: "const", value: 5, is_constant: true },
      { type: "assign", dst: "x", value: { type: "const", value: 10 } }
    ]
  }

  let cfg = {
    blocks: [{ id: 0, statements: [] }],
    edges: []
  }

  let pipeline = run_optimization_pipeline(ir, cfg, 2)
  return pipeline != null && pipeline.optimization_level == 2
}
