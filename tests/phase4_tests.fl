// Z-Lang Transpiler Phase 4: Code Generation Tests (25개 무관용 테스트)

// Group B1: Code Generation (5개)
fn test_b1_basic_instructions() -> bool {
  // mov, add, sub 기본 명령어
  let ctx = new_code_context()

  push(ctx.instructions, { type: "mov", dst: "rax", src: "rbx" })
  push(ctx.instructions, { type: "add", dst: "rax", src: "rcx" })
  push(ctx.instructions, { type: "sub", dst: "rax", src: "rdx" })

  return length(ctx.instructions) == 3
}

fn test_b1_function_calls() -> bool {
  // CALL, RET 함수 호출
  let ctx = new_code_context()

  push(ctx.instructions, { type: "call", func: "printf" })
  push(ctx.instructions, { type: "ret" })

  return length(ctx.instructions) == 2
}

fn test_b1_control_flow() -> bool {
  // JMP, CMP, JNE, JE 제어흐름
  let ctx = new_code_context()

  push(ctx.instructions, { type: "cmp", reg: "rax", imm: 0 })
  push(ctx.instructions, { type: "je", label: "zero_label" })
  push(ctx.instructions, { type: "jne", label: "nonzero_label" })
  push(ctx.instructions, { type: "jmp", label: "end_label" })

  return length(ctx.instructions) == 4
}

fn test_b1_memory_access() -> bool {
  // MOV [mem], LOAD, STORE 메모리 접근
  let ctx = new_code_context()

  push(ctx.instructions, { type: "mov", dst: "[rbp-8]", src: "rax" })
  push(ctx.instructions, { type: "mov", dst: "rbx", src: "[rbp-8]" })

  return length(ctx.instructions) == 2
}

fn test_b1_register_allocation() -> bool {
  // RAX, RBX, RCX 레지스터 할당
  let ctx = new_code_context()

  ctx = get_variable_register(ctx, "var1")
  ctx = get_variable_register(ctx, "var2")
  ctx = get_variable_register(ctx, "var3")

  return length(ctx.variables) == 3
}

// Group B2: Assembly Building (5개)
fn test_b2_instruction_encoding() -> bool {
  // 정확한 바이트 코드 인코딩
  let instr = build_instruction("mov", "rax", "rbx")
  instr = encode_instruction(instr)

  return instr.encoded != null && instr.size > 0
}

fn test_b2_label_resolution() -> bool {
  // 레이블 주소 계산
  let builder = new_assembly_builder()
  builder = add_section(builder, "text")

  builder = emit_label(builder, "start")
  builder = emit_instruction(builder, "mov", "rax", "rbx")
  builder = emit_label(builder, "end")

  builder = resolve_labels(builder)

  return length(builder.labels) >= 0
}

fn test_b2_section_management() -> bool {
  // .text, .data, .bss 섹션 관리
  let builder = new_assembly_builder()

  builder = add_section(builder, "text")
  builder = add_section(builder, "data")
  builder = add_section(builder, "bss")

  return length(builder.sections) == 3
}

fn test_b2_alignment() -> bool {
  // 16바이트 정렬
  let builder = new_assembly_builder()
  builder = add_section(builder, "text")

  let section = builder.sections[0]
  section.size = 25

  builder = align_sections(builder)

  return section.size == 32
}

fn test_b2_optimization() -> bool {
  // NOP 제거, JMP 축약
  let builder = new_assembly_builder()
  builder = add_section(builder, "text")

  builder = emit_instruction(builder, "mov", "rax", "rax")
  builder = emit_instruction(builder, "add", "rax", "rbx")

  builder = optimize_instructions(builder)

  return length(builder.sections[0].instructions) > 0
}

// Group B3: Register Management (5개)
fn test_b3_caller_saved() -> bool {
  // Caller-saved RAX, RCX, RDX, RSI, RDI, R8-R11
  let allocator = new_register_allocator()

  return is_caller_saved(allocator, "rax") && is_caller_saved(allocator, "rcx")
}

fn test_b3_callee_saved() -> bool {
  // Callee-saved RBX, RSP, RBP, R12-R15
  let allocator = new_register_allocator()

  return is_callee_saved(allocator, "rbx") && is_callee_saved(allocator, "r12")
}

fn test_b3_temporary_allocation() -> bool {
  // 임시 변수 자동 할당
  let allocator = new_register_allocator()

  let alloc1 = allocate_register(allocator, "temp1")
  let alloc2 = allocate_register(allocator, "temp2")

  return alloc1 != null && alloc2 != null
}

fn test_b3_spill_handling() -> bool {
  // 레지스터 부족 시 메모리 사용
  let allocator = new_register_allocator()

  // 모든 레지스터 사용
  let i = 0
  while i < 20 {
    allocate_register(allocator, "var" + string(i))
    i = i + 1
  }

  return length(allocator.spilled) > 0
}

fn test_b3_abi_compliance() -> bool {
  // System V AMD64 ABI 준수
  let allocator = new_register_allocator()

  let report = get_abi_compliance_report(allocator)

  return report != null && length(report) > 0
}

// Group B4: Stack Frame (5개)
fn test_b4_prologue_generation() -> bool {
  // PUSH RBP, MOV RSP, RBP, SUB RSP 생성
  let frame = new_stack_frame()

  let prologue = generate_prologue(frame)

  return length(prologue) >= 3
}

fn test_b4_epilogue_generation() -> bool {
  // MOV RSP, RBP, POP RBP, RET 생성
  let frame = new_stack_frame()

  let epilogue = generate_epilogue(frame)

  return length(epilogue) >= 3
}

fn test_b4_local_variable_allocation() -> bool {
  // [RBP-8], [RBP-16] 로컬 변수 할당
  let frame = new_stack_frame()

  frame = add_local_variable(frame, "x", 8)
  frame = add_local_variable(frame, "y", 8)

  return length(frame.local_variables) == 2
}

fn test_b4_argument_passing() -> bool {
  // RDI, RSI, RDX, RCX, R8, R9 인자 전달
  let frame = new_stack_frame()

  frame = add_argument(frame, "a", 0)
  frame = add_argument(frame, "b", 1)
  frame = add_argument(frame, "c", 2)

  return length(frame.arguments) == 3
}

fn test_b4_return_value() -> bool {
  // RAX, RDX (64비트 이상) 반환값
  let frame = new_stack_frame()

  let ret_reg = get_return_register()

  return ret_reg == "rax"
}

// Group B5: Integration E2E (5개)
fn test_b5_simple_function() -> bool {
  // int add(int a, int b) 단순 함수
  let ir = {
    functions: [{
      name: "add",
      args: ["a", "b"],
      body: [{ type: "return", value: { type: "literal", value: 5 } }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  return pipeline.code_context != null && pipeline.stats.functions == 1
}

fn test_b5_recursive_function() -> bool {
  // factorial(n) 재귀 함수
  let ir = {
    functions: [{
      name: "factorial",
      args: ["n"],
      body: [{ type: "call", name: "factorial" }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  return pipeline.code_context != null
}

fn test_b5_multiple_arguments() -> bool {
  // func(a, b, c, d, e, f) 여러 인자
  let ir = {
    functions: [{
      name: "func",
      args: ["a", "b", "c", "d", "e", "f"],
      body: [{ type: "return", value: { type: "literal", value: 0 } }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  return pipeline.stats.functions == 1
}

fn test_b5_loop_code_generation() -> bool {
  // for 루프 코드 생성
  let ir = {
    functions: [{
      name: "loop_func",
      args: [],
      body: [{
        type: "while",
        cond: { type: "literal", value: 1 },
        body: [{ type: "return", value: { type: "literal", value: 0 } }]
      }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  return pipeline.code_context != null
}

fn test_b5_elf_binary_generation() -> bool {
  // 실행 가능한 ELF 바이너리 생성
  let ir = {
    functions: [{
      name: "main",
      args: [],
      body: [{ type: "return", value: { type: "literal", value: 0 } }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  return validate_pipeline(pipeline) && verify_elf_binary(pipeline.elf_binary)
}
