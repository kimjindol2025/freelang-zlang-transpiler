// Z-Lang Transpiler Phase 4: Unforgiving Rules (5개 규칙 검증)

// Rule 1: Code Correctness
// 정의: 생성된 코드의 의미론 정확성 보장
// 검증: IR 실행 결과 = 어셈블리 실행 결과
fn verify_rule1_code_correctness() -> bool {
  // Test: 간단한 함수 int add(int a, int b) → return a + b
  let ir = {
    functions: [{
      name: "add",
      args: ["a", "b"],
      body: [{
        type: "return",
        value: {
          type: "binary_op",
          op: "+",
          left: { type: "variable", name: "a" },
          right: { type: "variable", name: "b" }
        }
      }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  // 생성된 코드가 의미론적으로 정확한가?
  let has_add_instr = false

  let i = 0
  while i < length(pipeline.code_context.instructions) {
    let instr = pipeline.code_context.instructions[i]
    if instr.op == "add" {
      has_add_instr = true
    }
    i = i + 1
  }

  return has_add_instr && pipeline.code_context != null
}

// Rule 2: Calling Convention
// 정의: System V AMD64 ABI 완벽 준수
// 검증: 인자 전달, 반환값, 레지스터 보존
fn verify_rule2_calling_convention() -> bool {
  // Test: 6개 인자 함수 func(a, b, c, d, e, f)
  let frame = new_stack_frame()

  frame = add_argument(frame, "a", 0)
  frame = add_argument(frame, "b", 1)
  frame = add_argument(frame, "c", 2)
  frame = add_argument(frame, "d", 3)
  frame = add_argument(frame, "e", 4)
  frame = add_argument(frame, "f", 5)

  // 처음 6개 인자는 RDI, RSI, RDX, RCX, R8, R9에 전달
  let arg_regs = get_argument_registers()

  let all_correct = true

  let i = 0
  while i < length(frame.arguments) && i < 6 {
    let arg = frame.arguments[i]
    if arg.register != arg_regs[i] {
      all_correct = false
    }
    i = i + 1
  }

  // 반환값은 RAX
  let ret_reg = get_return_register()
  if ret_reg != "rax" {
    all_correct = false
  }

  return all_correct
}

// Rule 3: Stack Safety
// 정의: 스택 오버플로우, 언더플로우 없음
// 검증: RSP 유효성 검사, 스택 얼라인먼트 16바이트
fn verify_rule3_stack_safety() -> bool {
  // Test: 스택 프레임이 16바이트로 정렬되어 있는가?
  let frame = new_stack_frame()

  frame = add_local_variable(frame, "x", 8)
  frame = add_local_variable(frame, "y", 8)
  frame = add_local_variable(frame, "z", 8)

  frame = align_stack(frame)

  // 정렬 후 크기가 16의 배수인가?
  let is_aligned = (frame.total_size % frame.alignment) == 0

  // 프롤로그/에필로그가 생성되는가?
  let prologue = generate_prologue(frame)
  let epilogue = generate_epilogue(frame)

  return is_aligned && length(prologue) > 0 && length(epilogue) > 0
}

// Rule 4: Register Efficiency
// 정의: 레지스터 할당 최적성 (> 80% 사용률)
// 검증: 스필 횟수 최소화
fn verify_rule4_register_efficiency() -> bool {
  // Test: 10개 변수 할당 후 스필 횟수 확인
  let allocator = new_register_allocator()

  let i = 0
  let spilled_count = 0

  while i < 10 {
    let alloc = allocate_register(allocator, "var" + string(i))

    if alloc.type == "spilled" {
      spilled_count = spilled_count + 1
    }

    i = i + 1
  }

  // 총 레지스터 수
  let total_regs = length(allocator.caller_saved) + length(allocator.callee_saved)

  // 스필되지 않은 변수 비율
  let allocated = 10 - spilled_count
  let efficiency = 100 * allocated / 10

  // 80% 이상 할당되어야 함 (2개 이상 스필되어야 함)
  return spilled_count >= 0 && efficiency >= 80
}

// Rule 5: Binary Compatibility
// 정의: 생성된 바이너리가 Linux x86-64에서 실행 가능
// 검증: ELF 형식, 실행 권한, 링킹
fn verify_rule5_binary_compatibility() -> bool {
  // Test: ELF 바이너리가 유효한 형식인가?
  let ir = {
    functions: [{
      name: "main",
      args: [],
      body: [{ type: "return", value: { type: "literal", value: 0 } }]
    }]
  }

  let pipeline = compile_to_binary(ir)

  // ELF 바이너리 검증
  let elf_valid = verify_elf_binary(pipeline.elf_binary)

  // 링킹 검증
  let linking_valid = verify_linking(pipeline.linker)

  // 엔트리 포인트 확인
  let has_entry_point = pipeline.linker.entry_point != null

  return elf_valid && linking_valid && has_entry_point
}

// 최종 검증 함수
fn run_phase4_unforgiving_rules() -> bool {
  let rule1_pass = verify_rule1_code_correctness()
  let rule2_pass = verify_rule2_calling_convention()
  let rule3_pass = verify_rule3_stack_safety()
  let rule4_pass = verify_rule4_register_efficiency()
  let rule5_pass = verify_rule5_binary_compatibility()

  let result = "Phase 4 Unforgiving Rules Verification:\\n"
  result = result + "Rule 1 (Code Correctness): "
  if rule1_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 2 (Calling Convention): "
  if rule2_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 3 (Stack Safety): "
  if rule3_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 4 (Register Efficiency): "
  if rule4_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 5 (Binary Compatibility): "
  if rule5_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  return rule1_pass && rule2_pass && rule3_pass && rule4_pass && rule5_pass
}
