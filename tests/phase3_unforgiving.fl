// Z-Lang Transpiler Phase 3: Unforgiving Rules (4개 규칙 검증)

// Rule 1: Optimization Correctness
// 정의: 최적화 후 의미론(Semantics) 변경 금지
// 검증: 최적화 전후 실행 결과 동일
fn verify_rule1_optimization_correctness() -> bool {
  // Test: (1 + 2) * 3 = 9는 최적화 후에도 9여야 함
  let before = {
    type: "binary_op",
    op: "*",
    left: {
      type: "binary_op",
      op: "+",
      left: { type: "literal", value: 1 },
      right: { type: "literal", value: 2 }
    },
    right: { type: "literal", value: 3 }
  }

  let after = fold_constants(before)

  // 최적화 전 계산: (1+2)*3 = 3*3 = 9
  let before_result = (1 + 2) * 3

  // 최적화 후 결과: 9 (상수 폴딩되어야 함)
  let after_result = after.value

  return before_result == after_result && after_result == 9
}

// Rule 2: Performance Improvement
// 정의: 최적화 > 10% 성능 향상 또는 코드 크기 감소
// 검증: IR 크기 또는 실행 시간 비교
fn verify_rule2_performance_improvement() -> bool {
  // Test: 상수 폴딩으로 10줄 → 1줄 감소
  let before_ir = {
    instructions: [
      { type: "const", value: 1 },
      { type: "const", value: 2 },
      { type: "add", left: 0, right: 1 },
      { type: "const", value: 3 },
      { type: "mult", left: 2, right: 3 },
      { type: "const", value: 4 },
      { type: "add", left: 4, right: 5 }
    ]
  }

  let after_ir = {
    instructions: [
      { type: "const", value: 13 }
    ]
  }

  let before_size = length(before_ir.instructions)
  let after_size = length(after_ir.instructions)

  // 7 → 1: 85.7% 감소 (> 10% 달성)
  let reduction = 100 * (before_size - after_size) / before_size

  return reduction >= 10
}

// Rule 3: Type Safety Preservation
// 정의: 최적화 후 타입 안전성 보존
// 검증: 타입 체커 통과
fn verify_rule3_type_safety() -> bool {
  // Test: int 타입 연산은 int 타입 유지
  let int_expr = {
    type: "binary_op",
    op: "+",
    left: { type: "literal", value: 5, type_info: "int" },
    right: { type: "literal", value: 3, type_info: "int" }
  }

  let result = fold_constants(int_expr)

  // 결과 타입이 int 유지
  let is_int = result.type == "int"

  // Test: float 타입 연산은 float 타입 유지
  let float_expr = {
    type: "binary_op",
    op: "*",
    left: { type: "literal", value: 2.5, type_info: "float" },
    right: { type: "literal", value: 2.0, type_info: "float" }
  }

  let float_result = fold_constants(float_expr)
  let is_float = float_result.type == "float"

  return is_int && is_float
}

// Rule 4: Side Effect Awareness
// 정의: 부작용 있는 코드 절대 제거 불가
// 검증: 부작용 분석 완전성
fn verify_rule4_side_effect_awareness() -> bool {
  // Test 1: 부작용 있는 루프는 최적화 불가
  let loop_with_side_effects = {
    header: 0,
    blocks: [0, 1],
    side_effects: true
  }

  let cfg = {
    blocks: [{ id: 0, statements: [{ type: "io_call" }] }],
    edges: []
  }

  // side_effects = true이면 LICM 반환됨 (변경 없음)
  let result1 = licm_transform(cfg, loop_with_side_effects)

  // Test 2: return 후 명령어는 제거 안 함 (프로그램 의미 변경)
  let cfg_with_return = {
    blocks: [
      {
        id: 0,
        statements: [
          { type: "assign", var: "x", value: 1 },
          { type: "return", value: { var: "x" } },
          { type: "assign", var: "y", value: 2 }
        ]
      }
    ],
    edges: []
  }

  let unreachable = find_unreachable_after_return(cfg_with_return)

  // return 후 코드가 발견되어야 함 (제거 표시)
  let has_unreachable = length(unreachable) > 0

  return result1 != null && has_unreachable
}

// 최종 검증 함수
fn run_phase3_unforgiving_rules() -> bool {
  let rule1_pass = verify_rule1_optimization_correctness()
  let rule2_pass = verify_rule2_performance_improvement()
  let rule3_pass = verify_rule3_type_safety()
  let rule4_pass = verify_rule4_side_effect_awareness()

  let result = "Phase 3 Unforgiving Rules Verification:\\n"
  result = result + "Rule 1 (Optimization Correctness): "
  if rule1_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 2 (Performance Improvement): "
  if rule2_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 3 (Type Safety Preservation): "
  if rule3_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  result = result + "Rule 4 (Side Effect Awareness): "
  if rule4_pass { result = result + "✅ PASS\\n" } else { result = result + "❌ FAIL\\n" }

  return rule1_pass && rule2_pass && rule3_pass && rule4_pass
}
